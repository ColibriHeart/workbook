<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Product Blueprint - Personal Development</title>
    <style>
        :root {
            --dark-blue: #1a2a44;
            --nature-green: #4a6741;
            --nature-beige: #f4f1ea;
            --white: #ffffff;
            --accent: #d4a373;
            --text-gray: #333;
        }

        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            background-color: var(--nature-beige);
            color: var(--text-gray);
            overflow-x: hidden;
        }

        header {
            background-color: var(--dark-blue);
            color: var(--white);
            padding: 20px;
            text-align: center;
            width: 100%;
            border-bottom: 4px solid var(--nature-green);
        }

        .main-container {
            display: flex;
            min-height: calc(100vh - 80px);
            width: 100%;
        }

        /* Sidebar Tabs - 30% */
        .sidebar {
            width: 30%;
            background-color: var(--dark-blue);
            color: var(--white);
            display: flex;
            flex-direction: column;
            border-right: 1px solid rgba(255,255,255,0.1);
        }

        .tab-button {
            padding: 20px 15px;
            cursor: pointer;
            border: none;
            background: none;
            color: var(--white);
            text-align: left;
            font-size: 1rem;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            transition: 0.3s;
        }

        .tab-button:hover {
            background-color: var(--nature-green);
        }

        .tab-button.active {
            background-color: var(--nature-green);
            border-left: 5px solid var(--accent);
        }

        /* Interactive Interface - 70% */
        .content-area {
            width: 70%;
            padding: 30px;
            overflow-y: auto;
            background-color: var(--white);
        }

        .card {
            background: var(--white);
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            border-top: 3px solid var(--nature-green);
        }

        /* Calculator Styles */
        .calc-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
        }

        .input-group input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }

        .revenue-display {
            background: var(--dark-blue);
            color: var(--white);
            padding: 20px;
            border-radius: 8px;
            text-align: center;
        }

        .revenue-amount {
            font-size: 2rem;
            font-weight: bold;
            color: #82c91e;
        }

        /* List Styles */
        .item-row {
            padding: 15px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
            transition: background 0.2s;
        }

        .item-row:hover {
            background: #f9f9f9;
        }

        .stats-detail {
            display: none;
            font-size: 0.85rem;
            color: #666;
            margin-top: 5px;
            font-style: italic;
        }

        /* Prompt Box Styles */
        .prompt-container {
            position: relative;
            background: #f8f9fa;
            border: 1px dashed var(--dark-blue);
            padding: 15px;
            margin: 15px 0;
            border-radius: 5px;
        }

        .prompt-text {
            font-family: monospace;
            font-size: 0.9rem;
            white-space: pre-wrap;
            max-height: 150px;
            overflow-y: auto;
            margin-bottom: 15px;
        }

        .copy-btn {
            background: var(--nature-green);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .copy-btn:active {
            transform: scale(0.98);
        }

        @media (max-width: 768px) {
            .main-container { flex-direction: column; }
            .sidebar, .content-area { width: 100%; }
            .sidebar { flex-direction: row; overflow-x: auto; }
            .tab-button { white-space: nowrap; padding: 10px; font-size: 0.8rem; }
        }
    </style>
</head>
<body>

<header>
    <h1>Personal Development Blueprint</h1>
    <p>Product: Interactive Workbook | Niche: Nature & Organic Lifestyle</p>
</header>

<div class="main-container">
    <div class="sidebar">
        <button class="tab-button active" onclick="showTab('dashboard')">🏠 Dashboard</button>
        <button class="tab-button" onclick="showTab('titles')">1. Product Titles</button>
        <button class="tab-button" onclick="showTab('competitors')">2. 10 Competitors</button>
        <button class="tab-button" onclick="showTab('domains')">3. 10 Domains</button>
        <button class="tab-button" onclick="showTab('blogs')">4. 10 Blog Ideas</button>
        <button class="tab-button" onclick="showTab('checklist')">5. Step-by-Step Checklist</button>
        <button class="tab-button" onclick="showTab('resources')">6. Resources</button>
    </div>

    <div class="content-area" id="main-content">
        
        <div id="dashboard" class="tab-content">
            <div class="card">
                <h2>Project Summary</h2>
                <p>You are launching an <strong>Interactive Workbook</strong> in the <strong>Personal Development</strong> niche. Your strategy focuses on <strong>Organic Growth</strong> aesthetics paired with <strong>Paid Traffic</strong> for rapid income generation via a dedicated <strong>Landing Page</strong>.</p>
            </div>

            <div class="card">
                <h3>Revenue Forecaster</h3>
                <div class="calc-grid">
                    <div class="input-group">
                        <label>Product Price ($)</label>
                        <input type="number" id="price" value="47" oninput="calculateRevenue()">
                    </div>
                    <div class="input-group">
                        <label>Daily Traffic (Visitors)</label>
                        <input type="number" id="traffic" value="500" oninput="calculateRevenue()">
                    </div>
                </div>
                <div class="revenue-display">
                    <p>Estimated Monthly Revenue (2% Conv.)</p>
                    <div class="revenue-amount" id="revenue-result">$9,400</div>
                </div>
            </div>
        </div>

        <div id="titles" class="tab-content" style="display:none;">
            <div class="card">
                <h2>Top Product Titles</h2>
                <p><small>*Ranked by Google Search Volume. Click to see monthly searches.</small></p>
                <div id="titles-list"></div>
            </div>
        </div>

        <div id="competitors" class="tab-content" style="display:none;">
            <div class="card">
                <h2>Direct Niche Competitors</h2>
                <p>Smaller, specialized creators in the Personal Development space.</p>
                <div id="competitors-list"></div>
            </div>
        </div>

        <div id="domains" class="tab-content" style="display:none;">
            <div class="card">
                <h2>Recommended Brand Names</h2>
                <div id="domains-list"></div>
            </div>
        </div>

        <div id="blogs" class="tab-content" style="display:none;">
            <div class="card">
                <h2>High-Intent Blog Topics</h2>
                <p><small>*Ranked by search demand. Click to reveal volume.</small></p>
                <div id="blogs-list"></div>
            </div>
        </div>

        <div id="checklist" class="tab-content" style="display:none;">
            <div class="card">
                <h2>Implementation Roadmap</h2>
                <div id="checklist-items"></div>
            </div>
        </div>

        <div id="resources" class="tab-content" style="display:none;">
            <div class="card">
                <h2>Build Instructions & Prompts</h2>
                
                <h3>Landing Page Construction</h3>
                <p>Use this prompt with <a href="https://bit.ly/3H4W2BF" target="_blank">Hostinger AI Website Builder</a>:</p>
                <div class="prompt-container">
                    <div class="prompt-text" id="prompt-landing">Create a high-converting landing page for an "Interactive Personal Development Workbook". Use a nature-inspired color palette (forest green, earth brown, cream). Section 1: Hero with strong headline and CTA. Section 2: Pain points of feeling stuck. Section 3: Interactive features of the workbook. Section 4: Social proof and testimonials. Section 5: Pricing table. Ensure the mobile view is optimized for one-thumb scrolling.</div>
                    <button class="copy-btn" onclick="copyText('prompt-landing')">Copy Prompt</button>
                </div>

                <h3>Digital Product Framework</h3>
                <p>Structure for your Workbook (Optimized for Search Demand):</p>
                <div class="prompt-container">
                    <div class="prompt-text" id="prompt-gamma">H2: Introduction to Holistic Self-Growth
H3: Identifying Your Internal Growth Obstacles
H2: The Daily Alignment Framework
H3: Science-Backed Journaling Exercises
H2: Nature-Based Mindfulness Techniques
H3: Tracking Progress & Habit Stacking
H2: Conclusion & Lifetime Mastery

Prompt for Gamma: Generate a 10-slide interactive digital workbook layout based on this structure. Use a 'Minimalist Nature' theme. Ensure every second slide includes an 'Actionable Input' box for user data.</div>
                    <button class="copy-btn" onclick="copyText('prompt-gamma')">Copy Prompt</button>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    // DATA ARRAYS
    const titlesData = [
        { name: "The Daily Mindset Shift Workbook", vol: "12,500" },
        { name: "Mindfulness & Growth Interactive Journal", vol: "9,200" },
        { name: "Holistic Habit Mastery Guide", vol: "8,100" },
        { name: "Natural Self-Discovery Journal", vol: "7,400" },
        { name: "The Intentional Living Workbook", vol: "6,800" },
        { name: "Inner Peace Digital Planner", vol: "5,500" },
        { name: "Clarity & Focus Interactive Guide", vol: "4,200" },
        { name: "The Self-Correction Blueprint", vol: "3,100" },
        { name: "Rooted Growth Journal", vol: "2,800" },
        { name: "Sustainable Self-Care Workbook", vol: "1,900" }
    ];

    const competitorsData = [
        { name: "The Happiness Planner", url: "https://thehappinessplanner.com" },
        { name: "Silk + Sonder", url: "https://www.silkandsonder.com" },
        { name: "Daily Reflection Co", url: "https://dailyreflection.co" },
        { name: "Mindful Productivity", url: "https://mindfulproductivityblog.com" },
        { name: "Wildflower Wisdom", url: "https://wildflowerwisdom.net" },
        { name: "The Journal Shop", url: "https://thejournalshop.com" },
        { name: "Growth Rooted", url: "https://growthrooted.com" },
        { name: "Self-Care Is For Everyone", url: "https://selfcareisforeveryone.com" },
        { name: "The Positive Planner", url: "https://thepositiveplanner.co.uk" },
        { name: "Earthly Growth", url: "https://earthlygrowth.com" }
    ];

    const domainsData = [
        "RootedGrowthWorkbooks.com", "NaturalMindsetHub.com", "TheOrganicGrowthKit.com", 
        "SelfDiscoveryNature.com", "InnerBloomInteractive.com", "EcoSpiritGrowth.com",
        "TheDailyZenWorkbook.com", "NatureNurtureSelf.com", "ModernGrowthForest.com", "MindfulSoil.com"
    ];

    const blogsData = [
        { name: "How to Start a Mindset Journal for Beginners", vol: "18,000" },
        { name: "5 Daily Habits to Improve Mental Clarity", vol: "15,200" },
        { name: "Why Interactive Workbooks Are Better Than eBooks", vol: "12,100" },
        { name: "The Science of Journaling and Growth", vol: "9,800" },
        { name: "How Nature Heals the Modern Mind", vol: "7,500" },
        { name: "How to Stay Productive Without Burning Out", vol: "6,900" },
        { name: "Finding Your Purpose in a Digital World", vol: "5,400" },
        { name: "The Best Mindfulness Tools for 2026", vol: "4,100" },
        { name: "Overcoming Procrastination Through Reflection", vol: "3,300" },
        { name: "Sustainable Self-Care Tips", vol: "2,100" }
    ];

    const checklistData = [
        "Finalize Niche: Nature-Based Personal Development",
        "Design Workbook in Canva/Gamma using Organic Scheme",
        "Export as Interactive PDF or Digital App",
        "Register Domain Name via Hostinger",
        "Set up Landing Page with AI Builder",
        "Integrate Stripe/PayPal for Payments",
        "Write 10 SEO-focused Blog Posts",
        "Set up Meta Ads (Paid Traffic Strategy)",
        "Launch to 'Early Bird' Email List",
        "Scale Ads based on ROAS (Return on Ad Spend)"
    ];

    // INITIALIZATION
    window.onload = function() {
        populateLists();
        calculateRevenue();
    };

    function populateLists() {
        // Titles
        const titlesList = document.getElementById('titles-list');
        titlesData.forEach(item => {
            const div = document.createElement('div');
            div.className = 'item-row';
            div.innerHTML = `<strong>${item.name}</strong><div class="stats-detail">Est. Monthly Searches: ${item.vol}</div>`;
            div.onclick = function() { this.querySelector('.stats-detail').style.display = 'block'; };
            titlesList.appendChild(div);
        });

        // Competitors
        const compList = document.getElementById('competitors-list');
        competitorsData.forEach(item => {
            const div = document.createElement('div');
            div.className = 'item-row';
            div.innerHTML = `<a href="${item.url}" target="_blank" style="text-decoration:none; color:var(--dark-blue);">🔗 ${item.name}</a>`;
            compList.appendChild(div);
        });

        // Domains
        const domList = document.getElementById('domains-list');
        domainsData.forEach(item => {
            const div = document.createElement('div');
            div.className = 'item-row';
            div.innerHTML = `🌐 ${item}`;
            domList.appendChild(div);
        });

        // Blogs
        const blogList = document.getElementById('blogs-list');
        blogsData.forEach(item => {
            const div = document.createElement('div');
            div.className = 'item-row';
            div.innerHTML = `<strong>${item.name}</strong><div class="stats-detail">Keyword Vol: ${item.vol}/mo</div>`;
            div.onclick = function() { this.querySelector('.stats-detail').style.display = 'block'; };
            blogList.appendChild(div);
        });

        // Checklist
        const checkList = document.getElementById('checklist-items');
        checklistData.forEach((item, index) => {
            const div = document.createElement('div');
            div.className = 'item-row';
            div.innerHTML = `<input type="checkbox" id="check${index}"> <label for="check${index}">${item}</label>`;
            checkList.appendChild(div);
        });
    }

    // CALCULATOR
    function calculateRevenue() {
        const price = document.getElementById('price').value;
        const traffic = document.getElementById('traffic').value;
        const convRate = 0.02; // 2%
        const monthly = traffic * convRate * price * 30;
        document.getElementById('revenue-result').innerText = '$' + monthly.toLocaleString();
    }

    // NAVIGATION
    function showTab(tabId) {
        const contents = document.querySelectorAll('.tab-content');
        contents.forEach(content => content.style.display = 'none');
        
        const buttons = document.querySelectorAll('.tab-button');
        buttons.forEach(btn => btn.classList.remove('active'));
        
        document.getElementById(tabId).style.display = 'block';
        event.currentTarget.classList.add('active');
    }

    // UTILITIES
    function copyText(id) {
        const text = document.getElementById(id).innerText;
        navigator.clipboard.writeText(text);
        const btn = event.target;
        btn.innerText = "COPIED!";
        setTimeout(() => { btn.innerText = "Copy Prompt"; }, 2000);
    }
</script>

</body>
</html>
